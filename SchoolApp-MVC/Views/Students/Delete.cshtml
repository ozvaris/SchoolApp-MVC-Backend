@model SchoolApp_MVC.Dtos.Students.StudentReadDto

@{
    ViewData["Title"] = "Delete Student";
}

<h1>Delete Student</h1>
<hr />

<div class="alert alert-danger">
    Are you sure you want to delete this student?
</div>

<dl class="row">
    <dt class="col-sm-2">ID</dt>
    <dd class="col-sm-10">@Model.StudentID</dd>

    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.StudentName</dd>

    <dt class="col-sm-2">Surname</dt>
    <dd class="col-sm-10">@Model.StudentSurname</dd>

    <dt class="col-sm-2">Email</dt>
    <dd class="col-sm-10">@Model.StudentEmail</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.StudentID" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
