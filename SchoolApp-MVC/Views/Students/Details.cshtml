@model SchoolApp_MVC.Dtos.Students.StudentReadDto

@{
    ViewData["Title"] = "Student Details";
}

<h1>Student Details</h1>
<hr />

<dl class="row">
    <dt class="col-sm-2">ID</dt>
    <dd class="col-sm-10">@Model.StudentID</dd>

    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.StudentName</dd>

    <dt class="col-sm-2">Surname</dt>
    <dd class="col-sm-10">@Model.StudentSurname</dd>

    <dt class="col-sm-2">Email</dt>
    <dd class="col-sm-10">@Model.StudentEmail</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.StudentID" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to List</a>
