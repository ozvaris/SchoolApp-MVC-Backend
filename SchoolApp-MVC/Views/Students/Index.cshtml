@model IReadOnlyList<SchoolApp_MVC.Dtos.Students.StudentReadDto>

@{
    ViewData["Title"] = "Students";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Students</h1>
    <a asp-action="Create" class="btn btn-primary">Create New Student</a>
</div>

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert alert-success" role="alert">
        @message
    </div>
}

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Surname</th>
            <th>Email</th>
            <th style="width: 220px;">Actions</th>
        </tr>
    </thead>
    <tbody>
    @if (!Model.Any())
    {
        <tr>
            <td colspan="5" class="text-center">No students found.</td>
        </tr>
    }
    else
    {
        @foreach (var student in Model)
        {
            <tr>
                <td>@student.StudentID</td>
                <td>@student.StudentName</td>
                <td>@student.StudentSurname</td>
                <td>@student.StudentEmail</td>
                <td>
                    <a asp-action="Details" asp-route-id="@student.StudentID" class="btn btn-sm btn-outline-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@student.StudentID" class="btn btn-sm btn-outline-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@student.StudentID" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    }
    </tbody>
</table>
