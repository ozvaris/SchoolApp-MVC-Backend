@model SchoolApp_MVC.Dtos.CourseEnrollments.CourseEnrollmentReadDto

@{
    ViewData["Title"] = "Delete Course Enrollment";
}

<h1>Delete Course Enrollment</h1>

<h3>Are you sure you want to delete this enrollment?</h3>

<dl class="row">
    <dt class="col-sm-2">Course</dt>
    <dd class="col-sm-10">@Model.CourseCode - @Model.CourseName</dd>
    <dt class="col-sm-2">Student</dt>
    <dd class="col-sm-10">@Model.StudentName @Model.StudentSurname</dd>
    <dt class="col-sm-2">Email</dt>
    <dd class="col-sm-10">@Model.StudentEmail</dd>
    <dt class="col-sm-2">Enrollment Date</dt>
    <dd class="col-sm-10">@(Model.EnrollmentDate?.ToString("yyyy-MM-dd") ?? "-")</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.CourseEnrollmentID" method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" asp-route-courseId="@Model.CourseID" class="btn btn-secondary">Back to List</a>
</form>
