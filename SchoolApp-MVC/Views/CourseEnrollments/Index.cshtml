@model SchoolApp_MVC.ViewModels.CourseEnrollments.CourseEnrollmentIndexViewModel

@{
    ViewData["Title"] = "Course Enrollments";
    var selectedCourse = Model.Courses.FirstOrDefault(course => course.CourseID == Model.SelectedCourseID);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Course Enrollments</h1>
</div>

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert alert-success" role="alert">
        @message
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}

<form asp-action="Index" method="get" class="row g-2 align-items-end mb-4">
    <div class="col-md-6">
        <label for="courseId" class="form-label">Course</label>
        <select id="courseId" name="courseId" class="form-select">
            @foreach (var course in Model.Courses)
            {
                <option value="@course.CourseID" selected="@(course.CourseID == Model.SelectedCourseID)">
                    @course.CourseCode - @course.CourseName
                </option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Select</button>
    </div>
</form>

@if (!Model.Courses.Any())
{
    <div class="alert alert-info" role="alert">
        No courses found. Create a course before adding enrollments.
    </div>
}
else if (selectedCourse is not null)
{
    <div class="mb-4">
        <h2 class="h4 mb-3">@selectedCourse.CourseCode - @selectedCourse.CourseName</h2>

        <form asp-action="Create" method="post" class="row g-2 align-items-end">
            <input type="hidden" name="CourseID" value="@Model.SelectedCourseID" />
            <div class="col-md-5">
                <label for="StudentID" class="form-label">Student</label>
                <select id="StudentID" name="StudentID" class="form-select" disabled="@(!Model.AvailableStudents.Any())">
                    @if (!Model.AvailableStudents.Any())
                    {
                        <option value="">No available students</option>
                    }
                    else
                    {
                        <option value="">Select student</option>
                        @foreach (var student in Model.AvailableStudents)
                        {
                            <option value="@student.StudentID">
                                @student.StudentName @student.StudentSurname (@student.StudentEmail)
                            </option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label for="EnrollmentDate" class="form-label">Enrollment Date</label>
                <input id="EnrollmentDate" name="EnrollmentDate" type="date" class="form-control" value="@Model.NewEnrollment.EnrollmentDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-success w-100" disabled="@(!Model.AvailableStudents.Any())">Add Student</button>
            </div>
        </form>
    </div>

    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Student</th>
                <th>Email</th>
                <th>Enrollment Date</th>
                <th style="width: 180px;">Actions</th>
            </tr>
        </thead>
        <tbody>
        @if (!Model.Enrollments.Any())
        {
            <tr>
                <td colspan="4" class="text-center">No students enrolled in this course.</td>
            </tr>
        }
        else
        {
            @foreach (var enrollment in Model.Enrollments)
            {
                <tr>
                    <td>@enrollment.StudentName @enrollment.StudentSurname</td>
                    <td>@enrollment.StudentEmail</td>
                    <td>@(enrollment.EnrollmentDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@enrollment.CourseEnrollmentID" class="btn btn-sm btn-outline-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@enrollment.CourseEnrollmentID" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
}
