@model IReadOnlyList<SchoolApp_MVC.Dtos.Courses.CourseReadDto>

@{
    ViewData["Title"] = "Courses";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Courses</h1>
    <a asp-action="Create" class="btn btn-primary">Create New Course</a>
</div>

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert alert-success" role="alert">
        @message
    </div>
}

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Code</th>
            <th>Credit</th>
            <th style="width: 220px;">Actions</th>
        </tr>
    </thead>
    <tbody>
    @if (!Model.Any())
    {
        <tr>
            <td colspan="5" class="text-center">No courses found.</td>
        </tr>
    }
    else
    {
        @foreach (var course in Model)
        {
            <tr>
                <td>@course.CourseID</td>
                <td>@course.CourseName</td>
                <td>@course.CourseCode</td>
                <td>@course.CourseCredit</td>
                <td>
                    <a asp-action="Details" asp-route-id="@course.CourseID" class="btn btn-sm btn-outline-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@course.CourseID" class="btn btn-sm btn-outline-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@course.CourseID" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    }
    </tbody>
</table>
